{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "groupName": "go",
      "matchDepNames": [
        "go",
        "docker.io/golang"
      ]
    },
    {
      "matchDepNames": "go",
      "minimumReleaseAge": "1 day"
    },
    {
      "matchFileNames": [
        "Dockerfile"
      ],
      "matchDatasources": [
        "docker"
      ],
      "semanticCommitType": "fix"
    },
    {
      "matchCurrentVersion": "!/^v?0/",
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    },
    {
      "matchDepNames": ["docker.io/golang"],
      "matchUpdateTypes":["digest"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        ".github/osv-scanner.toml"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "matchStrings": [
        "GoVersionOverride = \"(?<currentValue>.+?)\""
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}
